.env.example

# Application Settings
DEBUG=false
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# LLM Configuration
LLM_MODEL=deepseek:8b
LLM_BASE_URL=http://localhost:11434
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024

# Database Configuration
DATABASE_URL=sqlite:///./shadow_engine.db
DATABASE_ECHO=false

# Security
API_KEY=shadow-dev-key-12345
SECRET_KEY=shadow-secret-key-do-not-use-in-production

# Risk Thresholds
RISK_THRESHOLD_LOW=0.3
RISK_THRESHOLD_MEDIUM=0.6
RISK_THRESHOLD_HIGH=0.85

# Detection
ENABLE_REGEX_DETECTION=true
ENABLE_ANOMALY_DETECTION=true
ENABLE_LLM_DETECTION=true

# Learning
ENABLE_LEARNING=true
FEEDBACK_STORE_PATH=./data/feedback
THRESHOLD_ADJUSTMENT_ENABLED=true
